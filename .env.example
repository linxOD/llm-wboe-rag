# Environment Variables Configuration for WBOE RAG API

# Required: Logfire token for logging
LOGFIRE_TOKEN=your_logfire_token_here

# Backend API Keys (at least one is required)
# Uncomment and set the ones you want to use:

# Ollama Backend - for remote Ollama instances
# OLLAMA_API_KEY=your_ollama_jwt_token_here

# HuggingFace - for Llama CPP backend with GGUF models  
# HUGGINGFACE_API_KEY=your_huggingface_token_here

# OpenAI - for OpenAI models
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: API Server Configuration
# HOST=0.0.0.0
# PORT=8000
# WORKERS=1
# RELOAD=true
# LOG_LEVEL=info
